# -----------------------------------------------------------------------------
# GNM Head demo — environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and adjust as needed. Only NEXT_PUBLIC_* vars
# are read; they are inlined into the client bundle at build time.
#
# IMPORTANT: never put your fal API key here. The key is entered in the UI at
# runtime and lives only in the browser — it is never read from the environment,
# never sent to a server of ours, and never committed to git.
# -----------------------------------------------------------------------------

# The fal model endpoint (app id) to call. The app appends "/blend" and
# "/advanced" for those two modes automatically.
# Default: google/gnm-head
NEXT_PUBLIC_FAL_MODEL_ENDPOINT=google/gnm-head
